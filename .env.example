# ============================================================
# INTYRASENSE environment variables
# Copy this file to .env and fill in values:
# cp .env.example .env
# ============================================================

# ------------------------------
# Backend (FastAPI)
# ------------------------------
# Groq API key used by backend/models.py
GROQ_API_KEY=your_groq_api_key_here

# Supabase project URL used by backend/main.py and backend/supabase_client.py
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase API key used by backend/main.py and backend/supabase_client.py
SUPABASE_KEY=your_supabase_key_here

# ------------------------------
# Frontend (Streamlit)
# ------------------------------
# Backend base URL used by frontend/app.py
# Local default in code is http://localhost:8000
BACKEND_URL=http://localhost:8000
